@model IEnumerable<Order>
@{
    ViewData["Title"] = "الطلبات";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<h1>الطلبات</h1>

<table class="mt-3 table table-striped table-hover">
    <thead>
        <tr>
            <th>رقم الطلب</th>
            <th>اسم العميل</th>
            <th>البريد الإلكتروني</th>
            <th>رقم الهاتف</th>
            <th>العنوان</th>
            <th>تاريخ الطلب</th>
            <th>الحالة</th>
            <th>تغي الحاله</th>
            <th>التفاصيل</th>

        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var o in Model)
            {
                <tr>
                    <td>@o.OrderNo</td>
                    <td>@o.Name</td>
                    <td>@o.Email</td>
                    <td>@o.PhoneNo</td>
                    <td>@o.Address</td>
                    <td>@o.OrderDate</td>
                    <td>@o.Status</td>
                    <td>
                        <a asp-action="ChangeStauts" asp-controller="Order" class="btn btn-warning" asp-route-id="@o.Id">
                            <i class="fas fa-sync-alt"></i>
                        </a>
                    </td>
                    <td>
                        <a asp-action="GetDetails" asp-controller="Order" class="btn btn-success" asp-route-id="@o.Id">
                            <i class="fas fa-list"></i>
                        </a>
                    </td>

                </tr>
            }
        }
    </tbody>
</table>
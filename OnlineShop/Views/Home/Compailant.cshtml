@model Complaint
@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #0ea5e9;
        --secondary: #6366f1;
        --bg: #0f172a;
        --card: #111827;
        --text: #f1f5f9;
        --muted: #94a3b8;
        --border: #1f2937;
        --accent: #22c55e;
        --radius: 18px;
        --font: 'Cairo', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #0f172a, #020617);
        font-family: var(--font);
    }

    .complaint-section {
        max-width: 1100px;
        margin: 4rem auto;
        padding: 3rem;
        border-radius: var(--radius);
        background: linear-gradient(145deg, #111827, #020617);
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        border: 1px solid var(--border);
    }

    .form-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

        .form-header h2 {
            color: var(--text);
            font-size: 2.3rem;
            margin-bottom: 0.5rem;
        }

        .form-header p {
            color: var(--muted);
        }

    .complaint-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .contact-info-card {
        background: rgba(255,255,255,0.03);
        padding: 2rem;
        border-radius: var(--radius);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border);
    }

    .info-item {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.8rem;
    }

    .info-icon {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .info-content h4 {
        color: var(--text);
        margin: 0;
    }

    .info-content p {
        color: var(--muted);
        font-size: 0.85rem;
    }

    .form-control {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.03);
        color: var(--text);
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(14,165,233,0.3);
        }

    label {
        color: var(--muted);
        font-size: 0.85rem;
        margin-bottom: 0.4rem;
        display: block;
    }

    .btn-submit {
        width: 100%;
        padding: 1rem;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

    @@media(max-width:768px) {
        .complaint-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="complaint-section">
    <div class="form-header">
        <h2>صوتك يهمنا</h2>
        <p>شاركنا تجربتك وسنعمل على تحسينها فوراً</p>
    </div>

    <div class="complaint-grid">

        <div class="contact-info-card">
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-headset"></i></div>
                <div class="info-content">
                    <h4>دعم العملاء</h4>
                    <p>فريقنا جاهز لخدمتك على مدار الساعة</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="bi bi-lightning"></i></div>
                <div class="info-content">
                    <h4>استجابة سريعة</h4>
                    <p>نرد خلال 24 ساعة كحد أقصى</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="bi bi-shield-check"></i></div>
                <div class="info-content">
                    <h4>أمان تام</h4>
                    <p>بياناتك محمية بالكامل</p>
                </div>
            </div>
        </div>

        <form asp-action="Create" asp-controller="Complaint" method="post">

            <div class="form-group">
                <label>الاسم الكامل</label>
                <input asp-for="UserName" class="form-control" required>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label>رقم الهاتف</label>
                    <input asp-for="PhoneNumber" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني</label>
                    <input asp-for="UserEmail" class="form-control" required>
                </div>
            </div>

            <div class="form-group">
                <label>نوع الشكوى</label>
                <select asp-for="Type" class="form-control" required>
                    <option value="">اختر</option>
                    <option>مشكلة في التوصيل</option>
                    <option>عطل في المنتج</option>
                    <option>خدمة العملاء</option>
                    <option>مشكلة تقنية</option>
                </select>
            </div>

            <div class="form-group">
                <label>تفاصيل الشكوى</label>
                <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
            </div>

            <button class="btn-submit">إرسال الشكوى</button>
        </form>

    </div>
</div>

@model X.PagedList.IPagedList<Product>
@{
    ViewData["Title"] = "تويلاند — ألعاب سحرية لكل طفل!";
}

<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<!-- Floating Confetti -->
<div class="confetti-bg" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span><span></span>
</div>

<!-- HERO -->
<section class="tl-hero">
    <div class="hero-bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    <div class="hero-inner">
        <div class="hero-text">
            <div class="hero-eyebrow">🎊 أكثر من 5,000 طفل سعيد!</div>
            <h1 class="hero-title">
                <span class="line1">حيث تنبض كل</span><br />
                <span class="line2">خيالاتك</span><br />
                <span class="line3">بالحياة! 🚀</span>
            </h1>
            <p class="hero-desc">اكتشف ألعاباً سحرية ومغامرات ممتعة لكل طفل. آمنة وممتعة وتعليمية — للأعمار من 0 إلى 12 سنة!</p>
            <div class="hero-btns">
                <a asp-action="ShowProducts" class="btn-primary">تسوّق الآن 🎁</a>
                <a href="#age-guide" class="btn-secondary">اختر حسب العمر 🔍</a>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-num">+5,000</span>
                    <span class="hero-stat-lbl">طفل سعيد</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">+500</span>
                    <span class="hero-stat-lbl">علامة ألعاب</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">100%</span>
                    <span class="hero-stat-lbl">آمن ومعتمد</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-mini-toys" aria-hidden="true">
                <span class="mini-toy">🚂</span>
                <span class="mini-toy">🎨</span>
                <span class="mini-toy">🪀</span>
                <span class="mini-toy">🎮</span>
                <span class="mini-toy">🏆</span>
            </div>
            <span class="hero-big-emoji">🧸</span>
        </div>
    </div>
</section>

<!-- BANNER STRIP -->
<div class="banner-strip">
    <div class="banner-item"><i class="bi bi-truck"></i> شحن مجاني فوق 40$</div>
    <div class="banner-item"><i class="bi bi-shield-check"></i> معتمد 100% بالسلامة</div>
    <div class="banner-item"><i class="bi bi-arrow-counterclockwise"></i> إرجاع خلال 30 يوماً</div>
    <div class="banner-item"><i class="bi bi-gift"></i> تغليف هدايا مجاني</div>
</div>

<!-- CATEGORIES -->
<section class="categories-section">
    <div class="tl-container">
        <div class="section-header">
            <span class="section-eyebrow">🎠 استكشف</span>
            <h2 class="section-title">تسوّق حسب <span>الفئة</span></h2>
            <div class="section-underline"></div>
            <p class="section-sub">اعثر على اللعبة المثالية لكل نوع من أوقات اللعب</p>
        </div>
        <div class="categories-grid">
            <div class="cat-card cat-card-1">
                <span class="cat-emoji">🏗️</span>
                <p class="cat-name">بناء وليغو</p>
                <span class="cat-count">+120 منتجاً</span>
            </div>
            <div class="cat-card cat-card-2">
                <span class="cat-emoji">🎎</span>
                <p class="cat-name">دمى وشخصيات</p>
                <span class="cat-count">+85 منتجاً</span>
            </div>
            <div class="cat-card cat-card-3">
                <span class="cat-emoji">🎮</span>
                <p class="cat-name">ألعاب وبازل</p>
                <span class="cat-count">+200 منتجاً</span>
            </div>
            <div class="cat-card cat-card-4">
                <span class="cat-emoji">🎨</span>
                <p class="cat-name">فنون وحِرَف</p>
                <span class="cat-count">+95 منتجاً</span>
            </div>
            <div class="cat-card cat-card-5">
                <span class="cat-emoji">🚗</span>
                <p class="cat-name">سيارات وتحكم عن بُعد</p>
                <span class="cat-count">+140 منتجاً</span>
            </div>
        </div>
    </div>
</section>

<!-- PRODUCTS -->
<section class="products-section" id="products">
    <div class="section-header">
        <span class="section-eyebrow">⭐ أفضل الاختيارات</span>
        <h2 class="section-title">ألعاب <span>مميزة</span></h2>
        <div class="section-underline"></div>
        <p class="section-sub">الأطفال والآباء يحبونها — وستحبها أنت أيضاً!</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">🧸</span>
            <h3 class="empty-title">لا توجد ألعاب متاحة الآن!</h3>
            <p class="empty-text">تابعنا قريباً لمنتجات جديدة رائعة 🎉</p>
        </div>
    }
    else
    {
        <div class="products-grid">
            @foreach (var product in Model)
            {
                <div class="product-card">
                    <div class="product-img-wrap">
                        @if (product.Quantity < 10)
                        {
                            <span class="product-badge badge-hot">🔥 كمية محدودة</span>
                        }
                        else if (product.Price < 20)
                        {
                            <span class="product-badge badge-sale">💜 عرض رائع</span>
                        }
                        else
                        {
                            <span class="product-badge badge-new">✨ متوفر</span>
                        }
                        <button class="wishlist-btn" aria-label="أضف إلى المفضلة">🤍</button>
                        <img src="~/files/images/@product.Image"
                             alt="@product.Name"
                             class="product-image"
                             loading="lazy" />
                    </div>
                    <div class="product-body">
                        <div class="product-stock-tag">
                            <i class="bi bi-box-seam"></i> @product.Quantity في المخزون
                        </div>
                        <p class="product-name">@product.Name</p>
                        <div class="product-stars">
                            <span class="stars">★★★★★</span>
                            <span class="stars-count">(4.5)</span>
                        </div>
                        <div class="product-price-row">
                            <span class="price-now">$@product.Price.ToString("0.00")</span>
                        </div>
                        <a asp-action="Details"
                           asp-controller="Home"
                           asp-route-id="@product.Id"
                           class="add-to-cart">
                            <i class="bi bi-eye"></i> عرض التفاصيل
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
            {
                DisplayLinkToFirstPage = PagedListDisplayMode.Never,
                DisplayLinkToLastPage = PagedListDisplayMode.Never,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                LinkToPreviousPageFormat = "→ السابق",
                LinkToNextPageFormat = "التالي ←",
                UlElementClasses = new[] { "pagination-custom" },
                LiElementClasses = new[] { "page-item-custom" }
                })
    </div>
        }
</section>

<!-- AGE GUIDE -->
<section class="age-section" id="age-guide">
    <div class="tl-container" style="max-width:1000px">
        <div class="section-header">
            <span class="section-eyebrow">👶 تسوّق بذكاء</span>
            <h2 class="section-title">اعثر على ألعاب حسب <span>العمر</span></h2>
            <div class="section-underline"></div>
            <p class="section-sub">كل لعبة مصنّفة حسب مرحلة النمو المناسبة</p>
        </div>
        <div class="age-grid">
            <div class="age-card age-card-1">
                <span class="age-emoji">🍼</span>
                <div class="age-label">0 – 2 سنوات</div>
                <div class="age-desc">ألعاب حسية وأولى</div>
                <a asp-action="ShowProducts" class="age-btn">تصفّح ←</a>
            </div>
            <div class="age-card age-card-2">
                <span class="age-emoji">🦄</span>
                <div class="age-label">3 – 5 سنوات</div>
                <div class="age-desc">اللعب الإبداعي</div>
                <a asp-action="ShowProducts" class="age-btn">تصفّح ←</a>
            </div>
            <div class="age-card age-card-3">
                <span class="age-emoji">🏗️</span>
                <div class="age-label">6 – 8 سنوات</div>
                <div class="age-desc">البناء والإبداع</div>
                <a asp-action="ShowProducts" class="age-btn">تصفّح ←</a>
            </div>
            <div class="age-card age-card-4">
                <span class="age-emoji">🤖</span>
                <div class="age-label">9 – 12 سنة</div>
                <div class="age-desc">العلوم والتحديات</div>
                <a asp-action="ShowProducts" class="age-btn">تصفّح ←</a>
            </div>
        </div>
    </div>
</section>

<!-- REVIEWS -->
<section class="reviews-section">
    <div class="section-header">
        <span class="section-eyebrow">💬 عائلات سعيدة</span>
        <h2 class="section-title">ماذا يقول <span>الآباء</span></h2>
        <div class="section-underline"></div>
        <p class="section-sub">قصص حقيقية من عائلات حقيقية 💛</p>
    </div>
    <div class="reviews-grid tl-container">
        <div class="review-card">
            <div class="review-top">
                <div class="review-avatar review-avatar-1">👩</div>
                <div>
                    <div class="review-name">سارة م.</div>
                    <div class="review-role">أم لطفلين، أعمارهم 4 و7 سنوات</div>
                </div>
            </div>
            <div class="review-stars">★★★★★</div>
            <p class="review-text">"أطفالي يعشقون مجموعة البناء! يلعبون بها كل يوم منذ 3 أسابيع. أفضل شراء قمت به هذا العام. والشحن كان سريعاً جداً!"</p>
            <span class="review-toy">🏗️ مجموعة البناء</span>
        </div>
        <div class="review-card">
            <div class="review-top">
                <div class="review-avatar review-avatar-2">👨</div>
                <div>
                    <div class="review-name">جيمس ك.</div>
                    <div class="review-role">أب لطفل واحد، عمره 10 سنوات</div>
                </div>
            </div>
            <div class="review-stars">★★★★★</div>
            <p class="review-text">"لعبة الروبوت أبعدت ابني عن الشاشات وأعادته للعب الحقيقي! تويلاند دائماً يقدم منتجات ممتازة ممتعة وتعليمية في آنٍ واحد."</p>
            <span class="review-toy">🤖 لعبة الروبوت</span>
        </div>
        <div class="review-card">
            <div class="review-top">
                <div class="review-avatar review-avatar-3">👩</div>
                <div>
                    <div class="review-name">بريا ت.</div>
                    <div class="review-role">أم لثلاثة أطفال، أعمارهم 2 و5 و8 سنوات</div>
                </div>
            </div>
            <div class="review-stars">★★★★★</div>
            <p class="review-text">"أخيراً وجدت متجر ألعاب أثق به! كل شيء معتمد للسلامة، التغليف صديق للبيئة، وبناتي مجنونات بمجموعة استوديو الفن."</p>
            <span class="review-toy">🎨 استوديو الفن</span>
        </div>
    </div>
</section>

<!-- WHY US -->

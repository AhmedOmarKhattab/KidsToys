@model List<Product>
@{
    ViewData["Title"] = "سلة التسوق";
}

<!-- Page Header -->
<div class="cart-header" dir="rtl">
    <div class="cart-blob cart-blob-a"></div>
    <div class="cart-blob cart-blob-b"></div>
    <div class="cart-blob cart-blob-c"></div>
    <div class="cart-header-inner">
        <h1 class="cart-header-title">
            <div class="cart-header-icon">🛒</div>
            سلة التسوق
        </h1>
        @if (Model.Count > 0)
        {
            <div class="cart-count-badge">
                <i class="bi bi-bag-heart-fill"></i>
                @Model.Count @(Model.Count == 1 ? "منتج" : "منتجات")
            </div>
        }
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="cart-empty" dir="rtl">
        <div class="cart-empty-icon">🛒</div>
        <h3>سلتك فارغة!</h3>
        <p>لم تضف أي ألعاب بعد.<br />استعرض متجرنا واختر ما يعجب أطفالك 🧸</p>
        <a asp-action="ShowProducts" asp-controller="Home" class="cart-shop-btn">
            <i class="bi bi-shop"></i> تصفّح الألعاب 🎉
        </a>
    </div>
}
else
{
    <div class="cart-layout" dir="rtl">

        <!-- ── ITEMS ── -->
        <div class="cart-items-card">
            <div class="cart-items-head">
                <h3>🎁 ألعابك المختارة</h3>
                <span>@Model.Count منتج في السلة</span>
            </div>

            @foreach (var item in Model)
            {
                <div class="cart-item">
                    <div class="cart-item-img-wrap">
                        <img src="~/files/images/@item.Image"
                             alt="@item.Name"
                             class="cart-item-img"
                             onerror="this.src='/files/images/noimage.png'" />
                    </div>

                    <div class="cart-item-body">
                        <span class="cart-item-type">@(item.ProductType?.Name ?? "منتج")</span>
                        <div class="cart-item-name">@item.Name</div>
                        <div class="cart-item-meta">
                            @if (!string.IsNullOrEmpty(item.ProductColor))
                            {
                                <span>
                                    <span class="color-dot-sm" style="background:@item.ProductColor"></span>
                                    @item.ProductColor
                                </span>
                            }
                            <span><i class="bi bi-boxes"></i> الكمية: @item.Quantity</span>
                            <span><i class="bi bi-tag-fill"></i> @item.Price.ToString("0.00") ج.م / قطعة</span>
                        </div>
                    </div>

                    <div class="cart-item-right">
                        <div class="cart-item-price">@((item.Price * item.Quantity).ToString("0.00")) <sup>ج.م</sup></div>
                        <div class="cart-item-qty">× @item.Quantity قطعة</div>
                        <a asp-action="Remove" asp-controller="Home" asp-route-id="@item.Id"
                           class="cart-remove-btn">
                            <i class="bi bi-trash3-fill"></i> إزالة
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- ── SUMMARY ── -->
        <div class="cart-summary">
            <div class="cart-summary-head">
                <div class="cart-summary-head-icon">🧾</div>
                <div>
                    <h3>ملخص الطلب</h3>
                    <p>مراجعة المنتجات والإجمالي</p>
                </div>
            </div>
            <div class="cart-summary-body">

                @foreach (var item in Model)
                {
                    <div class="summary-row">
                        <span>@item.Name <small>×@item.Quantity</small></span>
                        <strong>@((item.Price * item.Quantity).ToString("0.00")) ج.م</strong>
                    </div>
                }

                <div class="summary-total">
                    <span class="summary-total-label">🎉 الإجمالي الكلي</span>
                    <span class="summary-total-amount">@Model.Sum(e => e.Price * e.Quantity).ToString("0.00") <sup>ج.م</sup></span>
                </div>

                <div class="summary-shipping">
                    <span>🚚</span>
                    الشحن مجاني على هذا الطلب!
                </div>

                <a asp-action="Checkout" asp-controller="Order" class="checkout-btn">
                    <i class="bi bi-credit-card-2-front-fill"></i>
                    إتمام الشراء
                </a>

                <a asp-action="Index" asp-controller="Home" class="continue-btn">
                    <i class="bi bi-arrow-right"></i>
                    متابعة التسوق
                </a>

                <div class="cart-trust">
                    <div class="trust-item">
                        <div class="trust-icon">🔒</div>
                        <span>دفع آمن</span>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">🛡️</div>
                        <span>ضمان الجودة</span>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">↩️</div>
                        <span>إرجاع مجاني</span>
                    </div>
                </div>

            </div>
        </div>

    </div>
}

<style>
    /*
         * Inherits from Index.cshtml (shared layout):
         * --orange, --pink, --yellow, --blue, --purple, --green,
         * --light-bg, --text, --muted, --bounce
         * Fonts: Cairo, Tajawal, Fredoka One  |  Bootstrap Icons
         */

    /* ── HEADER ── */
    .cart-header {
        background: linear-gradient(135deg, #1e1b2e 0%, #2d1f3d 55%, #1a2640 100%);
        padding: 2.5rem 0 2rem;
        position: relative;
        overflow: hidden;
        margin-bottom: 2.5rem;
    }

    .cart-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.28;
        pointer-events: none;
    }

    .cart-blob-a {
        width: 300px;
        height: 300px;
        background: var(--orange);
        top: -120px;
        right: -60px;
    }

    .cart-blob-b {
        width: 200px;
        height: 200px;
        background: var(--pink);
        bottom: -60px;
        left: 8%;
    }

    .cart-blob-c {
        width: 150px;
        height: 150px;
        background: var(--yellow);
        top: 10%;
        left: 42%;
        opacity: 0.15;
    }

    .cart-header-inner {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cart-header-title {
        color: white;
        font-family: 'Fredoka One', 'Cairo', cursive;
        font-size: 1.9rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cart-header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(10px);
        border: 1.5px solid rgba(255,255,255,0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .cart-count-badge {
        background: linear-gradient(135deg, var(--orange), var(--pink));
        color: white;
        font-size: 0.82rem;
        font-weight: 800;
        padding: 0.4rem 1.1rem;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        box-shadow: 0 4px 16px rgba(255,107,53,0.4);
    }

    /* ── EMPTY STATE ── */
    .cart-empty {
        max-width: 480px;
        margin: 5rem auto;
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 32px;
        box-shadow: 0 8px 40px rgba(255,107,53,0.1);
        border: 3px dashed rgba(255,107,53,0.2);
    }

    .cart-empty-icon {
        font-size: 5rem;
        margin-bottom: 1.25rem;
        display: block;
        animation: floatBig 3s ease-in-out infinite;
    }

    .cart-empty h3 {
        font-family: 'Fredoka One', 'Cairo', cursive;
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--text);
        margin-bottom: 0.5rem;
    }

    .cart-empty p {
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 2rem;
        line-height: 1.7;
    }

    .cart-shop-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        background: linear-gradient(135deg, var(--orange), var(--pink));
        color: white;
        border-radius: 50px;
        font-family: 'Cairo', sans-serif;
        font-weight: 800;
        font-size: 1rem;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(255,107,53,0.4);
        transition: transform 0.25s var(--bounce), box-shadow 0.25s;
    }

        .cart-shop-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 36px rgba(255,107,53,0.5);
            color: white;
        }

    /* ── LAYOUT ── */
    .cart-layout {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem 5rem;
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 1.5rem;
        align-items: start;
    }

    /* ── ITEMS CARD ── */
    .cart-items-card {
        background: white;
        border-radius: 28px;
        border: 2px solid rgba(255,107,53,0.1);
        box-shadow: 0 6px 28px rgba(255,107,53,0.08);
        overflow: hidden;
    }

    .cart-items-head {
        padding: 1.25rem 1.75rem;
        border-bottom: 2px dashed rgba(255,107,53,0.12);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #fff8f0, #fff0e0);
    }

        .cart-items-head h3 {
            font-family: 'Fredoka One', 'Cairo', cursive;
            font-size: 1.1rem;
            font-weight: 900;
            color: var(--text);
            margin: 0;
        }

        .cart-items-head span {
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--orange);
            background: rgba(255,107,53,0.1);
            padding: 0.3rem 0.85rem;
            border-radius: 50px;
        }

    /* Each item row */
    .cart-item {
        display: grid;
        grid-template-columns: 100px 1fr auto;
        gap: 1.25rem;
        padding: 1.5rem 1.75rem;
        border-bottom: 2px dashed rgba(255,107,53,0.08);
        align-items: center;
        transition: background 0.2s;
    }

        .cart-item:last-child {
            border-bottom: none;
        }

        .cart-item:hover {
            background: linear-gradient(135deg, #fffdf9, #fff8f0);
        }

    .cart-item-img-wrap {
        width: 100px;
        height: 90px;
        border-radius: 18px;
        overflow: hidden;
        border: 2px solid rgba(255,107,53,0.12);
        background: linear-gradient(135deg, #fff8f0, #fff0e0);
        flex-shrink: 0;
    }

    .cart-item-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s var(--bounce);
    }

    .cart-item:hover .cart-item-img {
        transform: scale(1.08);
    }

    .cart-item-body {
        min-width: 0;
    }

    .cart-item-type {
        font-size: 0.72rem;
        font-weight: 800;
        color: var(--orange);
        background: linear-gradient(135deg, #fff0e0, #fde8d8);
        border: 1.5px solid rgba(255,107,53,0.2);
        padding: 0.2rem 0.75rem;
        border-radius: 50px;
        display: inline-block;
        margin-bottom: 0.4rem;
    }

    .cart-item-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 0.4rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cart-item-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--muted);
        font-weight: 600;
    }

        .cart-item-meta span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .cart-item-meta i {
            color: var(--orange);
            font-size: 0.75rem;
        }

    .color-dot-sm {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid white;
        box-shadow: 0 0 0 1.5px rgba(0,0,0,0.12);
        display: inline-block;
    }

    .cart-item-right {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.65rem;
    }

    .cart-item-price {
        font-family: 'Fredoka One', 'Cairo', cursive;
        font-size: 1.3rem;
        color: var(--orange);
        white-space: nowrap;
        display: flex;
        align-items: baseline;
        gap: 0.2rem;
    }

        .cart-item-price sup {
            font-size: 0.72rem;
            font-family: 'Cairo', sans-serif;
            font-weight: 800;
        }

    .cart-item-qty {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--muted);
        background: var(--light-bg);
        border: 1.5px solid rgba(255,107,53,0.15);
        border-radius: 10px;
        padding: 0.25rem 0.7rem;
        white-space: nowrap;
    }

    .cart-remove-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.9rem;
        background: rgba(239,68,68,0.07);
        color: #ef4444;
        border: 1.5px solid rgba(239,68,68,0.2);
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 800;
        font-family: 'Cairo', sans-serif;
        text-decoration: none;
        transition: all 0.2s var(--bounce);
        cursor: pointer;
    }

        .cart-remove-btn:hover {
            background: rgba(239,68,68,0.14);
            border-color: rgba(239,68,68,0.4);
            color: #ef4444;
            transform: translateY(-2px);
        }

    /* ── SUMMARY ── */
    .cart-summary {
        background: white;
        border-radius: 28px;
        border: 2px solid rgba(255,107,53,0.1);
        box-shadow: 0 6px 28px rgba(255,107,53,0.08);
        overflow: hidden;
        position: sticky;
        top: 1.5rem;
    }

    .cart-summary-head {
        background: linear-gradient(135deg, #1e1b2e, #2d1f3d);
        padding: 1.5rem 1.75rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .cart-summary-head-icon {
        font-size: 2rem;
        line-height: 1;
        background: rgba(255,255,255,0.1);
        border-radius: 14px;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .cart-summary-head h3 {
        font-family: 'Fredoka One', 'Cairo', cursive;
        font-size: 1.05rem;
        font-weight: 900;
        color: white;
        margin: 0 0 0.2rem;
    }

    .cart-summary-head p {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.45);
        margin: 0;
        font-weight: 600;
    }

    .cart-summary-body {
        padding: 1.5rem 1.75rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.87rem;
        padding: 0.7rem 0;
        border-bottom: 1px dashed rgba(255,107,53,0.12);
        color: var(--muted);
        font-weight: 600;
    }

        .summary-row:last-of-type {
            border-bottom: none;
        }

        .summary-row small {
            color: var(--muted);
            font-size: 0.78rem;
        }

        .summary-row strong {
            color: var(--text);
            font-weight: 800;
        }

    .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 1.25rem;
        background: linear-gradient(135deg, #fff0e0, #fde8d8);
        border-radius: 18px;
        margin: 1rem 0;
        border: 2px solid rgba(255,107,53,0.2);
    }

    .summary-total-label {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--text);
    }

    .summary-total-amount {
        font-family: 'Fredoka One', 'Cairo', cursive;
        font-size: 1.7rem;
        color: var(--orange);
        display: flex;
        align-items: baseline;
        gap: 0.2rem;
    }

        .summary-total-amount sup {
            font-size: 0.8rem;
            font-family: 'Cairo', sans-serif;
            font-weight: 800;
        }

    .summary-shipping {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem;
        background: rgba(74,222,128,0.1);
        border: 1.5px solid rgba(74,222,128,0.3);
        border-radius: 14px;
        font-size: 0.84rem;
        color: #16a34a;
        font-weight: 800;
        margin-bottom: 1.25rem;
    }

    .checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, var(--orange), var(--pink));
        color: white;
        border: none;
        border-radius: 16px;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        font-weight: 800;
        text-decoration: none;
        transition: transform 0.25s var(--bounce), box-shadow 0.25s;
        box-shadow: 0 8px 24px rgba(255,107,53,0.4);
        margin-bottom: 0.75rem;
        cursor: pointer;
    }

        .checkout-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 36px rgba(255,107,53,0.5);
            color: white;
        }

    .continue-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.85rem;
        background: white;
        color: var(--muted);
        border: 2px solid rgba(255,107,53,0.15);
        border-radius: 16px;
        font-family: 'Cairo', sans-serif;
        font-size: 0.9rem;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.2s var(--bounce);
    }

        .continue-btn:hover {
            border-color: var(--orange);
            color: var(--orange);
            background: linear-gradient(135deg, #fff0e0, #fde8d8);
            transform: translateY(-2px);
        }

    /* Trust icons */
    .cart-trust {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
        padding-top: 1.25rem;
        border-top: 2px dashed rgba(255,107,53,0.1);
        margin-top: 1.25rem;
    }

    .trust-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.7rem;
        color: var(--muted);
        font-weight: 700;
        text-align: center;
    }

    .trust-icon {
        font-size: 1.5rem;
        line-height: 1;
        transition: transform 0.2s var(--bounce);
    }

    .trust-item:hover .trust-icon {
        transform: scale(1.3);
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 900px) {
        .cart-layout {
            grid-template-columns: 1fr;
        }

        .cart-summary {
            position: static;
        }
    }

    @@media (max-width: 576px) {
        .cart-layout {
            padding: 0 1rem 3rem;
        }

        .cart-item {
            grid-template-columns: 80px 1fr;
            gap: 0.85rem;
        }

        .cart-item-right {
            grid-column: 1 / -1;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }

        .cart-item-img-wrap {
            width: 80px;
            height: 72px;
        }

        .cart-header-inner {
            padding: 0 1rem;
        }
    }
</style>
